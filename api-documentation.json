          },
          "responses": {
            "200": {
              "description": "Shop created successfully"
            }
          }
        },
        {
          "name": "Get Shops",
          "method": "GET",
          "path": "/shops",
          "authentication": true,
          "description": "Get all shops owned by authenticated user",
          "responses": {
            "200": {
              "description": "List of shops"
            }
          }
        }
      ]
    },
    "plants": {
      "basePath": "/plants",
      "description": "Plant product management for sellers",
      "endpoints": [
        {
          "name": "Create Plant",
          "method": "POST",
          "path": "/plants",
