{
  "info": {
    "name": "ByteForge Auth API",
    "description": "Complete API documentation for ByteForge authentication and backend services",
    "version": "1.0.0",
    "baseUrl": "http://localhost:3005/api/v1"
  },
  "auth": {
    "type": "cookie",
    "cookieName": "session",
    "description": "Authentication is handled via HTTP-only session cookies"
  },
  "endpoints": {
    "user_auth": {
      "basePath": "/user/auth",
      "description": "User authentication endpoints",
      "endpoints": [
        {
          "name": "Register User",
          "method": "POST",
          "path": "/user/auth/register",
          "authentication": false,
          "description": "Register a new user account",
          "requestBody": {
            "type": "application/json",
            "schema": {
              "firstName": {
                "type": "string",
                "required": true,
                "minLength": 1,
                "maxLength": 50,
                "pattern": "^[a-zA-Z]+$",
                "description": "User's first name (letters only)"
              },
              "lastName": {
                "type": "string",
                "required": true,
                "minLength": 1,
                "maxLength": 50,
                "pattern": "^[a-zA-Z]+$",
                "description": "User's last name (letters only)"
              },
              "userName": {
                "type": "string",
                "required": true,
                "minLength": 3,
                "maxLength": 50,
                "pattern": "^[a-z0-9_]+$",
                "description": "Unique username (lowercase letters, numbers, underscores only)"
              },
              "email": {
                "type": "string",
                "required": true,
                "format": "email",
                "maxLength": 255,
                "description": "Valid email address"
              },
              "password": {
                "type": "string",
                "required": true,
                "minLength": 8,
                "maxLength": 255,
                "description": "Password must contain: uppercase, lowercase, number, special character"
              }
            },
            "example": {
              "firstName": "John",
              "lastName": "Doe",
              "userName": "johndoe_123",
              "email": "john@example.com",
              "password": "SecurePass123!"
            }
          },
          "responses": {
            "201": {
              "description": "User successfully registered",
              "example": {
                "success": true,
                "message": "New user created",
                "data": {
                  "user": {
                    "id": "68b45d92-0bc8-43c9-873e-ef225fe39666",
                    "firstName": "John",
                    "lastName": "Doe",
                    "userName": "johndoe_123",
                    "avatar": null,
                    "emailVerifiedAt": null,
                    "emailVerified": false,
                    "createdAt": "2026-01-13T02:26:10.246Z",
                    "updatedAt": "2026-01-13T02:26:10.246Z"
                  },
                  "localAuth": {
                    "id": "4d03a726-bcf3-45e5-bb27-585195343219",
                    "userId": "68b45d92-0bc8-43c9-873e-ef225fe39666",
                    "email": "john@example.com",
                    "verified": false,
                    "createdAt": "2026-01-13T02:26:10.246Z",
                    "updatedAt": "2026-01-13T02:26:10.246Z"
                  }
                }
              }
            },
            "409": {
              "description": "Duplicate username or email",
              "examples": {
                "duplicateUsername": {
                  "success": false,
                  "message": "Username already exists",
                  "error": {
                    "code": "DUPLICATE_ENTRY",
                    "details": "Username already exists"
                  },
                  "statusCode": 409,
                  "timestamp": "2026-01-13T13:23:35.604Z"
                },
                "duplicateEmail": {
                  "success": false,
                  "message": "Email already exists",
                  "error": {
                    "code": "DUPLICATE_ENTRY",
                    "details": "Email already exists"
                  },
                  "statusCode": 409,
                  "timestamp": "2026-01-13T13:26:40.300Z"
                }
              }
            },
            "400": {
              "description": "Validation error - invalid input data",
              "example": {
                "success": false,
                "message": "Validation failed",
                "error": {
                  "code": "VALIDATION_ERROR",
                  "details": "Check validationErrors array for details",
                  "validationErrors": [
                    {
                      "field": "email",
                      "message": "Invalid email"
                    }
                  ]
                },
                "statusCode": 400,
                "timestamp": "2026-01-13T13:23:35.604Z"
              }
            }
          }
        },
        {
          "name": "Login User",
          "method": "POST",
          "path": "/auth/login",
          "authentication": false,
          "description": "Login with email and password, returns session cookie",
          "requestBody": {
            "type": "application/json",
            "schema": {
              "email": {
                "type": "string",
                "required": true,
                "format": "email"
              },
              "password": {
                "type": "string",
                "required": true
              }
            },
            "example": {
              "email": "john@example.com",
              "password": "SecurePass123!"
            }
          },
          "responses": {
            "200": {
              "description": "Login successful, session cookie set",
              "example": {
                "success": true,
                "message": "User logged in",
                "data": {
                  "session": {
                    "id": "session_id",
                    "userId": "user_id"
                  }
                }
              }
            }
          }
        },
        {
          "name": "Check Auth Status",
          "method": "GET",
          "path": "/auth/check",
          "authentication": true,
          "description": "Check if user is authenticated and get user details",
          "responses": {
            "200": {
              "description": "User is authenticated",
              "example": {
                "id": "user_id",
                "email": "john@example.com",
                "firstName": "John",
                "lastName": "Doe"
              }
            },
            "401": {
              "description": "Unauthorized access"
            }
          }
        },
        {
          "name": "Verify Email",
          "method": "POST",
          "path": "/auth/verify-email",
          "authentication": true,
          "description": "Verify user email with OTP code",
          "requestBody": {
            "type": "application/json",
            "schema": {
              "otp": {
                "type": "string",
                "required": true,
                "description": "6-digit OTP code sent to email"
              }
            },
            "example": {
              "otp": "123456"
            }
          },
          "responses": {
            "200": {
              "description": "Email verified successfully",
              "example": {
                "success": true,
                "message": "Email verified successfully"
              }
            }
          }
        },
        {
          "name": "Send Verification Email",
          "method": "POST",
          "path": "/auth/send-verification-email",
          "authentication": true,
          "description": "Resend email verification code",
          "responses": {
            "200": {
              "description": "Verification code sent",
              "example": {
                "success": true,
                "message": "Verification code sent to your email"
              }
            }
          }
        }
      ]
    },
    "user_profile": {
      "basePath": "/profile",
      "description": "User profile management",
      "endpoints": [
        {
          "name": "Get User Profile",
          "method": "GET",
          "path": "/profile",
          "authentication": true,
          "description": "Get authenticated user's profile information",
          "responses": {
            "200": {
              "description": "User profile data"
            }
          }
        }
      ]
    },
    "media": {
      "basePath": "/media",
      "description": "Media upload and management",
      "endpoints": [
        {
          "name": "Upload Media",
          "method": "POST",
          "path": "/media/upload",
          "authentication": true,
          "description": "Upload image or video file",
          "requestBody": {
            "type": "multipart/form-data",
            "schema": {
              "file": {
                "type": "file",
                "required": true,
                "description": "Image or video file to upload"
              }
            }
          },
          "responses": {
            "200": {
              "description": "File uploaded successfully",
              "example": {
                "success": true,
                "data": {
                  "url": "https://cloudinary.com/...",
                  "publicId": "media_id"
                }
              }
            }
          }
        },
        {
          "name": "Delete Media",
          "method": "DELETE",
          "path": "/media/:id",
          "authentication": true,
          "description": "Delete uploaded media by ID",
          "parameters": {
            "id": {
              "type": "string",
              "in": "path",
              "required": true,
              "description": "Media ID to delete"
            }
          },
          "responses": {
            "200": {
              "description": "Media deleted successfully"
            }
          }
        },
        {
          "name": "Get All Media",
          "method": "GET",
          "path": "/media",
          "authentication": true,
          "description": "Get all media uploaded by authenticated user",
          "responses": {
            "200": {
              "description": "List of media files"
            }
          }
        }
      ]
    },
    "business_account": {
      "basePath": "/business-account",
      "description": "Business account management for sellers",
      "endpoints": [
        {
          "name": "Create Business Account",
          "method": "POST",
          "path": "/business-account",
          "authentication": true,
          "description": "Create a business account for selling",
          "requestBody": {
            "type": "application/json",
            "description": "Business account details"
          },
          "responses": {
            "200": {
              "description": "Business account created"
            }
          }
        },
        {
          "name": "Get Business Account",
          "method": "GET",
          "path": "/business-account",
          "authentication": true,
          "description": "Get authenticated user's business account",
          "responses": {
            "200": {
              "description": "Business account data"
            }
          }
        }
      ]
    },
    "shops": {
      "basePath": "/shops",
      "description": "Shop management for sellers",
      "endpoints": [
        {
          "name": "Create Shop",
          "method": "POST",
          "path": "/shops",
          "authentication": true,
          "description": "Create a new shop",
          "requestBody": {
            "type": "application/json",
