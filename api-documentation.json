  "notes": {
    "authentication": "Most endpoints require authentication via session cookie. Public endpoints are marked with 'authentication: false'",
    "baseUrl": "The base URL should be configured based on your environment (development/production)",
    "errorHandling": "All endpoints return standard error responses with appropriate HTTP status codes",
    "validation": "Request bodies are validated using Zod schemas. Validation errors will return 400 Bad Request with detailed error messages"
  }
