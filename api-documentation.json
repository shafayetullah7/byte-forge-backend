            "200": {
              "description": "Plant updated successfully"
            }
          }
        },
        {
          "name": "Delete Plant",
          "method": "DELETE",
          "path": "/plants/:id",
          "authentication": true,
          "description": "Delete a plant product",
          "parameters": {
            "id": {
              "type": "string",
              "in": "path",
              "required": true
            }
          },
          "responses": {
            "200": {
              "description": "Plant deleted successfully"
            }
          }
        }
      ]
    },
