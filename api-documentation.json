          "requestBody": {
            "type": "application/json",
            "description": "Plant product details"
          },
          "responses": {
            "200": {
              "description": "Plant created successfully"
            }
          }
        },
        {
          "name": "Get All Plants",
          "method": "GET",
          "path": "/plants",
          "authentication": true,
          "description": "Get all plants listed by authenticated seller",
          "responses": {
            "200": {
              "description": "List of plants"
            }
          }
        },
        {
          "name": "Get Plant by ID",
          "method": "GET",
          "path": "/plants/:id",
          "authentication": true,
          "description": "Get specific plant details",
          "parameters": {
            "id": {
              "type": "string",
              "in": "path",
              "required": true
            }
          },
          "responses": {
            "200": {
              "description": "Plant details"
            }
          }
        },
        {
          "name": "Update Plant",
          "method": "PATCH",
          "path": "/plants/:id",
          "authentication": true,
          "description": "Update plant product details",
          "parameters": {
            "id": {
              "type": "string",
              "in": "path",
              "required": true
            }
          },
          "requestBody": {
            "type": "application/json",
            "description": "Updated plant details"
          },
