# Email Configuration
MAIL_PROVIDER=gmail # Options: gmail, smtp, sendgrid, console
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password # Gmail App Password (not regular password)
MAIL_FROM_NAME=ByteForge Auth
MAIL_FROM_EMAIL=noreply@byteforge.com
