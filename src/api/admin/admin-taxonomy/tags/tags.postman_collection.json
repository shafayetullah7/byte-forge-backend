{
  "info": {
    "name": "Admin Tags API",
    "description": "Endpoints for managing global Tags logic and their specific translations in ByteForge Admin.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tags Base",
      "item": [
        {
          "name": "Get Tag by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tags/:tagId",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "tags", ":tagId"],
              "variable": [
                { "key": "tagId", "value": "{{tagId}}" }
              ]
            }
          }
        },
        {
          "name": "Update Tag",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"new-tag-slug\",\n  \"isActive\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/tags/:tagId",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "tags", ":tagId"],
              "variable": [
                { "key": "tagId", "value": "{{tagId}}" }
              ]
            }
          }
        },
        {
          "name": "Update Tag (Move to new Group)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"groupId\": \"{{newGroupId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/tags/:tagId",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "tags", ":tagId"],
              "variable": [
                { "key": "tagId", "value": "{{tagId}}" }
              ]
            }
          }
        },
        {
          "name": "Delete Tag",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tags/:tagId",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "tags", ":tagId"],
              "variable": [
                { "key": "tagId", "value": "{{tagId}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tag Translations",
      "item": [
        {
          "name": "Get Tag Translations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tags/:tagId/translations",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "tags", ":tagId", "translations"],
              "variable": [
                { "key": "tagId", "value": "{{tagId}}" }
              ]
            }
          }
        },
        {
          "name": "Upsert Tag Translation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"locale\": \"fr\",\n  \"name\": \"Étiquette Exemple\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/tags/:tagId/translations",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "tags", ":tagId", "translations"],
              "variable": [
                { "key": "tagId", "value": "{{tagId}}" }
              ]
            }
          }
        },
        {
          "name": "Delete Tag Translation",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tags/:tagId/translations/:locale",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "tags", ":tagId", "translations", ":locale"],
              "variable": [
                { "key": "tagId", "value": "{{tagId}}" },
                { "key": "locale", "value": "fr" }
              ]
            }
          }
        }
      ]
    }
  ]
}
