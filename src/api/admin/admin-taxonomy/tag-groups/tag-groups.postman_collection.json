{
  "info": {
    "name": "Admin Tag Groups API",
    "description": "Endpoints for managing Tag Groups and sub-resource logic (Tags creation within groups, translations) in ByteForge Admin.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tag Groups Base",
      "item": [
        {
          "name": "Create Tag Group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"sample-group-slug\",\n  \"isActive\": true,\n  \"translations\": [\n    {\n      \"locale\": \"en\",\n      \"name\": \"Sample Group\",\n      \"description\": \"Description for the sample group.\"\n    }\n  ],\n  \"tags\": [\n    {\n      \"slug\": \"sample-tag-slug\",\n      \"isActive\": true,\n      \"translations\": [\n        {\n          \"locale\": \"en\",\n          \"name\": \"Sample Tag\"\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups"
              ]
            }
          }
        },
        {
          "name": "Get All Tag Groups",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups?page=1&limit=10&sortOrder=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "sortOrder",
                  "value": "desc"
                }
              ]
            },
            "description": "Retrieves a paginated list of Tag Groups. The English locale translation is flattened directly onto the group object (`name`), and an array of up to 3 active child `tags` is embedded in the response."
          }
        },
        {
          "name": "Get Tag Group by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups/:groupId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups",
                ":groupId"
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "{{groupId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Update Tag Group",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"new-group-slug\",\n  \"isActive\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups/:groupId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups",
                ":groupId"
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "{{groupId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Tag Group",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups/:groupId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups",
                ":groupId"
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "{{groupId}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Group Translations",
      "item": [
        {
          "name": "Get Group Translations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups/:groupId/translations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups",
                ":groupId",
                "translations"
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "{{groupId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Upsert Group Translation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"locale\": \"fr\",\n  \"name\": \"Groupe Exemple\",\n  \"description\": \"Description francaise\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups/:groupId/translations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups",
                ":groupId",
                "translations"
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "{{groupId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Group Translation",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups/:groupId/translations/:locale",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups",
                ":groupId",
                "translations",
                ":locale"
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "{{groupId}}"
                },
                {
                  "key": "locale",
                  "value": "fr"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Group Tags Sub-resource",
      "item": [
        {
          "name": "Create Tag strictly in Group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"sample-tag-slug-2\",\n  \"isActive\": true,\n  \"translations\": [\n    {\n      \"locale\": \"en\",\n      \"name\": \"Sample Tag 2\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups/:groupId/tags",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups",
                ":groupId",
                "tags"
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "{{groupId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Tags by Group",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/tag-groups/:groupId/tags?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "tag-groups",
                ":groupId",
                "tags"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "{{groupId}}"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}